{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DroidLink",
  "version": "1.0.0",
  "identifier": "com.droidlink.app",
  "build": {
    "frontendDist": "../src/renderer/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "width": 1040,
        "height": 720,
        "minWidth": 300,
        "minHeight": 720,
        "decorations": true,
        "transparent": false,
        "center": true,
        "title": "DroidLink",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.icns", "icons/icon.ico"],
    "targets": "all",
    "resources": [
      "../resources/companion-app.apk",
      "../resources/scrcpy/adb",
      "../resources/scrcpy/scrcpy",
      "../resources/scrcpy/scrcpy-server"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    }
  }
}
